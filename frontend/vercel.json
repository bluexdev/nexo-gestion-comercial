{
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://backend-production-05fcc.up.railway.app/api/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
