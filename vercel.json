{
  "installCommand": "npm ci",
  "buildCommand": "npm run build -w frontend",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://backend-production-05fcc.up.railway.app/api/$1"
    },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
